# Discord Bot 配置
DISCORD_BOT_TOKEN=你的Discord_Bot_Token
DISCORD_SERVER_ID=你的服务器ID
ADMIN_ROLE_ID=管理员角色ID（可选）

# 數據庫配置
DATABASE_PATH=discord_tags.db

# Cloudflare D1 配置（雲端數據庫）
USE_D1=false
CLOUDFLARE_ACCOUNT_ID=你的Cloudflare_Account_ID
CLOUDFLARE_DATABASE_ID=你的D1數據庫ID
CLOUDFLARE_API_TOKEN=你的Cloudflare_API_Token

# 其他配置
MAX_HISTORY_DAYS=365